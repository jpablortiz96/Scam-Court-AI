# Scam Court AI — Environment Template
# Copy this file to .env and fill in values only when needed.
# The heuristic MVP requires NO secrets and NO API keys.
#
# How to use:
#   1. Copy this file:  Copy-Item .env.example .env
#   2. Edit .env (never commit it)
#   3. Restart your terminal or VS Code

# ---------------------------------------------------------------------------
# Text analysis backend
# ---------------------------------------------------------------------------
SCAM_COURT_BACKEND=heuristic

# ---------------------------------------------------------------------------
# Vision backend
# ---------------------------------------------------------------------------
# Safe default: none (fast startup, no model download)
# Activate vision: minicpm_v (requires pip install -r requirements.txt)
SCAM_COURT_VISION_BACKEND=none
SCAM_COURT_VISION_MODEL=openbmb/MiniCPM-V-4

# ---------------------------------------------------------------------------
# Cache paths — move to D: if C: drive is small
# See docs/WINDOWS_D_DRIVE_SETUP.md for full instructions
# ---------------------------------------------------------------------------
# HF_HOME=D:\AI_CACHE\huggingface
# HUGGINGFACE_HUB_CACHE=D:\AI_CACHE\huggingface\hub
# TRANSFORMERS_CACHE=D:\AI_CACHE\huggingface\transformers
# TORCH_HOME=D:\AI_CACHE\torch
# PIP_CACHE_DIR=D:\AI_CACHE\pip

# ---------------------------------------------------------------------------
# Optional: Hugging Face Hub token (higher rate limits)
# ---------------------------------------------------------------------------
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Optional: Modal (GPU batch jobs)
# ---------------------------------------------------------------------------
# MODAL_TOKEN_ID=ak-xxxxxxxxxxxx
# MODAL_TOKEN_SECRET=as-xxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Optional: App config
# ---------------------------------------------------------------------------
# DEBUG=false
# PORT=7860
# GRADIO_SERVER_PORT=7861
