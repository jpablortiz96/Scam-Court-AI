# Scam Court AI — Environment Template
# Copy this file to .env and fill in values only when needed.
# The heuristic MVP requires NO secrets and NO API keys.

# ---------------------------------------------------------------------------
# Optional: Hugging Face Hub (only when loading model backends)
# ---------------------------------------------------------------------------
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Optional: Modal (only for GPU batch evaluation jobs)
# ---------------------------------------------------------------------------
# MODAL_TOKEN_ID=ak-xxxxxxxxxxxx
# MODAL_TOKEN_SECRET=as-xxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Optional: Backend selection
# ---------------------------------------------------------------------------
# SCAM_COURT_BACKEND=heuristic   # Options: heuristic | smollm3

# ---------------------------------------------------------------------------
# Optional: App config
# ---------------------------------------------------------------------------
# DEBUG=false
# PORT=7860
